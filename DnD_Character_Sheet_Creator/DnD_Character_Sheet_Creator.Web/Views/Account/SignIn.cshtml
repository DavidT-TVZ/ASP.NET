@model DnD_Character_Sheet_Creator.Web.ViewModels.AccountSignInViewModel

@{
    ViewData["Title"] = "Sign In";
}

<section class="sheet-card mb-4 reveal">
    <p class="sheet-kicker mb-1">Gate of Names</p>
    <h1 class="h3 mb-1">Enter the ledger</h1>
    <p class="text-muted mb-0">Use your username and password to access your adventurer account.</p>
</section>

<div class="row justify-content-center">
    <div class="col-12 col-lg-7">
        <div class="scroll-opening reveal mb-4" data-scroll-opening>
            <div class="scroll-opening__rod scroll-opening__rod--top" aria-hidden="true"></div>
            <div class="card sheet-card scroll-opening__sheet">
                <div class="scroll-opening__glow scroll-opening__glow--left" aria-hidden="true"></div>
                <div class="scroll-opening__glow scroll-opening__glow--right" aria-hidden="true"></div>
                <div class="card-body">
                    <form asp-action="SignIn" asp-controller="Account" method="post">
                        <input type="hidden" asp-for="ReturnUrl" />

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="UserName" class="form-label"></label>
                            <input asp-for="UserName" class="form-control" autocomplete="username" />
                            <span asp-validation-for="UserName" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <div class="d-flex flex-wrap gap-2 align-items-end">
                            <button type="submit" class="btn btn-ink scroll-opening__cta">Enter Ledger</button>
                            <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-ink">Register</a>
                            <a asp-controller="Account" asp-action="ExternalLogin" asp-route-provider="Google" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-ink">Google login</a>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-ink">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
            <div class="scroll-opening__rod scroll-opening__rod--bottom" aria-hidden="true"></div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}