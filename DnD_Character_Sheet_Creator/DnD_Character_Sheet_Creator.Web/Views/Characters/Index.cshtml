@model IEnumerable<DnD_Character_Sheet_Creator.Web.ViewModels.CharacterWithPlayerViewModel>

@{
    ViewData["Title"] = "Characters";
    var searchQuery = ViewData["SearchQuery"] as string ?? string.Empty;
    var canManageCharacters = User?.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Manager"));
}

<div class="sheet-card mb-4 reveal d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div>
        <p class="sheet-kicker mb-1">Hero Ledger</p>
        <h1 class="h3 mb-1">Characters</h1>
        <p class="text-muted mb-0">Browse every recorded hero and their player associations.</p>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        @if (canManageCharacters)
        {
            <a asp-controller="Characters" asp-action="Create" class="btn btn-create">Create Character</a>
        }
        <span id="characterCountBadge" class="badge chronicle-badge rounded-pill px-3 py-2">@Model.Count() shown</span>
    </div>
</div>

<div class="sheet-card mb-4 reveal ajax-list-search-shell" data-search-url="@Url.Action("Search", "Characters")" data-autocomplete-url="@Url.Action("Autocomplete", "Characters")" data-count-badge="#characterCountBadge">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-8 position-relative ajax-list-search-field">
            <label for="characterSearchInput" class="form-label">Search characters</label>
            <input id="characterSearchInput" class="form-control ajax-list-search-input" type="search" placeholder="Search by name, player, class, level, race, background, or alignment" autocomplete="off" value="@searchQuery" />
            <div id="characterAutocomplete" class="list-group ajax-list-search-autocomplete d-none"></div>
        </div>
        <div class="col-12 col-lg-4">
            <p class="text-muted mb-0 small">Live search and autocomplete run through AJAX.</p>
        </div>
    </div>
</div>

<div id="characterListRegion" class="ajax-list-search-region">
    @await Html.PartialAsync("_CharacterCards", Model)
</div>
