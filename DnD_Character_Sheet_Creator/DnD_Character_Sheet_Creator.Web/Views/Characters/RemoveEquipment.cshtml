@model DnD_Character_Sheet_Creator.Models.Equipment

@{
    ViewData["Title"] = "Remove Equipment";
}

<section class="sheet-card mb-4 reveal">
    <p class="sheet-kicker mb-1">Remove Gear</p>
    <h1 class="h3 mb-1">@ViewData["Title"]</h1>
</section>

<div class="row justify-content-center">
    <div class="col-12 col-lg-6">
        <div class="card sheet-card reveal mb-4">
            <div class="card-body">
                <p>Are you sure you want to remove <strong>@Model.Name</strong> from this character?</p>

                <form asp-action="RemoveEquipment" asp-controller="Characters" method="post">
                    <input type="hidden" name="characterId" value="@Model.CharacterId" />
                    <div class="d-flex gap-2">
                        <button type="submit" formaction="@Url.Action("RemoveEquipment", "Characters", new { characterId = Model.CharacterId, equipmentId = Model.EquipmentId })" class="btn btn-danger">Remove</button>
                        <a asp-action="Details" asp-route-id="@Model.CharacterId" class="btn btn-outline-ink">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>