@model EquipmentManagementViewModel

@{
    ViewData["Title"] = "Equipment";
    var canDeleteCustomEquipment = User?.Identity?.IsAuthenticated == true && User.IsInRole("Admin");
}

<section class="sheet-card mb-4 reveal">
    <p class="sheet-kicker mb-1">Equipment Archive</p>
    <h1 class="h3 mb-1">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">Admins and managers can browse the full catalog and add custom equipment. Only admins can delete custom entries.</p>
</section>

<div class="row g-4">
    <div class="col-12 col-xl-5">
        <div class="card sheet-card reveal mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Add custom equipment</h2>
                <form asp-action="Create" asp-controller="Equipment" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label"></label>
                        <input asp-for="Type" class="form-control" />
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="Cost" class="form-label"></label>
                            <input asp-for="Cost" class="form-control" />
                            <span asp-validation-for="Cost" class="text-danger small d-block mt-1"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Weight" class="form-label"></label>
                            <input asp-for="Weight" class="form-control" />
                            <span asp-validation-for="Weight" class="text-danger small d-block mt-1"></span>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-create">Add custom item</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-7">
        <div class="card sheet-card reveal mb-4">
            <div class="card-body">
                <form asp-action="Index" asp-controller="Equipment" method="get" class="mb-4">
                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-lg-9">
                            <label for="query" class="form-label">Search equipment</label>
                            <input id="query" name="query" value="@Model.Query" class="form-control" type="search" placeholder="Search by name, type, cost, or weight" autocomplete="off" />
                        </div>
                        <div class="col-12 col-lg-3 d-grid">
                            <button type="submit" class="btn btn-ink">Search</button>
                        </div>
                    </div>
                </form>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Existing equipment</h2>
                    <span class="badge chronicle-badge rounded-pill">@Model.EquipmentItems.Count</span>
                </div>

                @if (!Model.EquipmentItems.Any())
                {
                    <div class="alert parchment-alert mb-0" role="status">No equipment matches your search.</div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var equipment in Model.EquipmentItems)
                        {
                            var isCustomEquipment = equipment.GetType() == typeof(Equipment);

                            <div class="col-12 col-md-6 ajax-list-search-item">
                                <div class="card sheet-card card-hover h-100 reveal">
                                    <div class="card-body">
                                        <div class="d-flex flex-wrap gap-2 align-items-start justify-content-between mb-2">
                                            <h3 class="h5 card-title mb-0">@equipment.Name</h3>
                                            @if (isCustomEquipment)
                                            {
                                                <span class="badge bg-secondary">Custom</span>
                                            }
                                        </div>
                                        <p class="card-text mb-1"><strong>Type:</strong> @(equipment.Type ?? "Equipment")</p>
                                        <p class="card-text mb-1"><strong>Cost:</strong> @equipment.Cost gp</p>
                                        <p class="card-text mb-0"><strong>Weight:</strong> @equipment.Weight</p>
                                    </div>
                                    <div class="card-footer bg-transparent border-top-0">
                                        <div class="d-flex flex-wrap gap-2">
                                            @if (canDeleteCustomEquipment && isCustomEquipment)
                                            {
                                                <form asp-action="Delete" asp-route-id="@equipment.EquipmentId" method="post" class="m-0">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}