@model DnD_Character_Sheet_Creator.Models.Player
@using DnD_Character_Sheet_Creator.Models
@using DnD_Character_Sheet_Creator.Web.ViewModels

@{
    ViewData["Title"] = "Player Details";
    var characters = ViewBag.Characters as IEnumerable<CharacterWithPlayerViewModel> ?? Enumerable.Empty<CharacterWithPlayerViewModel>();
}

<section class="sheet-card mb-4 reveal">
    <p class="sheet-kicker mb-1">Guild Member Dossier</p>
    <h1 class="h3 mb-0">Player Details</h1>
</section>

<div class="mb-4">
    <div class="d-flex gap-2">
        <a class="btn btn-outline-ink" asp-controller="Players" asp-action="Index">Back to all players</a>
        <a class="btn btn-edit" asp-controller="Players" asp-action="Edit" asp-route-id="@Model.PlayerId">Edit Player</a>
        <a class="btn btn-outline-danger" asp-controller="Players" asp-action="Remove" asp-route-id="@Model.PlayerId">Remove Player</a>
    </div>
</div>

<div class="card sheet-card mb-4 reveal">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name @Model.Surname</dd>

            <dt class="col-sm-3">Username</dt>
            <dd class="col-sm-9">@Model.Username</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Last Login</dt>
            <dd class="col-sm-9"><time datetime="@Model.LastLogin.ToString("o")">@Model.LastLogin.ToString("u")</time></dd>
        </dl>
    </div>
</div>

<h2 class="h4 mb-3">Characters</h2>
<div class="mb-3">
    <a class="btn btn-create" asp-controller="Characters" asp-action="Create" asp-route-playerId="@Model.PlayerId">Create Character</a>
</div>
<div class="sheet-card mb-4 reveal ajax-list-search-shell" data-search-url="@Url.Action("CharactersSearch", "Players", new { id = Model.PlayerId })" data-autocomplete-url="@Url.Action("CharactersAutocomplete", "Players", new { id = Model.PlayerId })" data-count-badge="#playerCharacterCountBadge">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-8 position-relative ajax-list-search-field">
            <label for="playerCharacterSearchInput" class="form-label">Search characters</label>
            <input id="playerCharacterSearchInput" class="form-control ajax-list-search-input" type="search" placeholder="Search by name, class, level, race, background, or alignment" autocomplete="off" />
            <div id="playerCharacterAutocomplete" class="list-group ajax-list-search-autocomplete d-none"></div>
        </div>
        <div class="col-12 col-lg-4">
            <p class="text-muted mb-0 small">Search stays within this player's character list.</p>
        </div>
    </div>
</div>

<div class="mb-3 d-flex justify-content-between align-items-center gap-2">
    <span id="playerCharacterCountBadge" class="badge chronicle-badge rounded-pill px-3 py-2">@characters.Count() shown</span>
</div>

<div id="playerCharacterListRegion" class="ajax-list-search-region">
@if (!characters.Any())
{
    <div class="alert parchment-alert" role="status">This player has no characters in the mock repository.</div>
}
else
{
    @await Html.PartialAsync("_PlayerCharacters", characters)
}
</div>
