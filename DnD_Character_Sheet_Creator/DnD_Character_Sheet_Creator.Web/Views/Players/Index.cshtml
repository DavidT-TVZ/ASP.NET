@model IEnumerable<DnD_Character_Sheet_Creator.Models.Player>

@{
    ViewData["Title"] = "Players";
    var searchQuery = ViewData["SearchQuery"] as string ?? string.Empty;
    var canCreatePlayer = User?.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Manager"));
}

<div class="sheet-card mb-4 reveal d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div>
        <p class="sheet-kicker mb-1">Guild Register</p>
        <h1 class="h3 mb-1">Players</h1>
        <p class="text-muted mb-0">Explore all registered players and their linked heroes.</p>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-2">
        @if (canCreatePlayer)
        {
            <a asp-controller="Players" asp-action="Create" class="btn btn-create">Create Player</a>
        }
        <span id="playerCountBadge" class="badge chronicle-badge rounded-pill px-3 py-2">@Model.Count() shown</span>
    </div>
</div>

<div class="sheet-card mb-4 reveal ajax-list-search-shell" data-search-url="@Url.Action("Search", "Players")" data-autocomplete-url="@Url.Action("Autocomplete", "Players")" data-count-badge="#playerCountBadge">
    <div class="row g-3 align-items-end">
        <div class="col-12 col-lg-8 position-relative ajax-list-search-field">
            <label for="playerSearchInput" class="form-label">Search players</label>
            <input id="playerSearchInput" class="form-control ajax-list-search-input" type="search" placeholder="Search by name, surname, username, email, or id" autocomplete="off" value="@searchQuery" />
            <div id="playerAutocomplete" class="list-group ajax-list-search-autocomplete d-none"></div>
        </div>
        <div class="col-12 col-lg-4">
            <p class="text-muted mb-0 small">Live search and autocomplete run through AJAX.</p>
        </div>
    </div>
</div>

<div id="playerListRegion" class="ajax-list-search-region">
    @await Html.PartialAsync("_PlayerCards", Model)
</div>
