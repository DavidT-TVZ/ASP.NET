@model DnD_Character_Sheet_Creator.Models.Player

@{
    ViewData["Title"] = "Remove Player";
}

<section class="sheet-card mb-4 reveal">
    <p class="sheet-kicker mb-1">Guild Removal</p>
    <h1 class="h3 mb-1">@ViewData["Title"]</h1>
    <p class="text-muted mb-0">This will soft-delete the player and hide them from lists.</p>
</section>

<div class="row justify-content-center">
    <div class="col-12 col-lg-7">
        <div class="card sheet-card reveal mb-4">
            <div class="card-body">
                <p>Are you sure you want to remove <strong>@Model.Name @Model.Surname</strong>?</p>
                <p class="mb-4 text-muted">The record will be marked as deleted and excluded from player lists.</p>

                <form asp-action="Remove" asp-controller="Players" method="post">
                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-danger">Remove Player</button>
                        <a asp-action="Details" asp-route-id="@Model.PlayerId" class="btn btn-outline-ink">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>