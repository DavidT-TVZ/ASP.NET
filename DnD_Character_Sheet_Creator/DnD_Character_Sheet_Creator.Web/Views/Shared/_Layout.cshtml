<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Adventurer Ledger</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cardo:wght@400;700&family=Cinzel+Decorative:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DnD_Character_Sheet_Creator.Web.styles.css" asp-append-version="true" />
</head>
<body class="theme-parchment">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header>
        <nav class="navbar navbar-expand-lg chronicle-nav mb-4" aria-label="Main navigation">
            <div class="container-lg">
                <a class="navbar-brand chronicle-brand" asp-area="" asp-controller="Home" asp-action="Index">The Adventurer Ledger</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Codex" asp-action="Index">Codex</a>
                        </li>
                        @if (User?.Identity?.IsAuthenticated == true && (User.IsInRole("Admin") || User.IsInRole("Manager")))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Players" asp-action="Index">Players</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Characters" asp-action="Index">Characters</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    <div class="d-flex flex-wrap align-items-center gap-2 gap-lg-3 mt-3 mt-lg-0 navbar-user-shell">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            var roleNames = User.Claims
                                .Where(claim => claim.Type == System.Security.Claims.ClaimTypes.Role)
                                .Select(claim => claim.Value)
                                .Distinct()
                                .ToList();
                            var roleLabel = roleNames.Count == 0 ? "User" : string.Join(", ", roleNames);

                            <div class="text-end small">
                                <div class="fw-bold">@((User.FindFirst("FullName")?.Value) ?? User.Identity?.Name)</div>
                                <div class="text-muted">@roleLabel</div>
                            </div>
                            <a class="btn btn-outline-ink btn-sm" asp-controller="Account" asp-action="Profile">Profile</a>
                            <form asp-controller="Account" asp-action="SignOut" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-ink btn-sm">Sign out</button>
                            </form>
                        }
                        else
                        {
                            <div class="d-flex gap-2 flex-wrap">
                                <a class="btn btn-ink btn-sm" asp-controller="Account" asp-action="SignIn">Sign in</a>
                                <a class="btn btn-outline-ink btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" role="main" class="container-lg pb-4 reveal">
        @RenderBody()
    </main>

    <footer class="chronicle-footer text-muted">
        <div class="container-lg">
            <span>&copy; @DateTime.UtcNow.Year Adventurer Ledger</span>
            <span class="mx-2 chronicle-footer-separator" aria-hidden="true">|</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Codex</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
