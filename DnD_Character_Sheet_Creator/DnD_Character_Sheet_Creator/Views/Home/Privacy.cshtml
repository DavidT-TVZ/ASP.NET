@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="sheet-card reveal" aria-labelledby="privacy-title">
    <p class="sheet-kicker mb-2">Guild Codex</p>
    <h1 id="privacy-title" class="mb-3">@ViewData["Title"]</h1>
    <p class="mb-3">
        This codex explains how campaign records are handled, displayed, and protected within the Adventurer Ledger.
    </p>
    <div class="sheet-note">
        Add your official policy text here, including data retention, account handling, and any table-sharing practices.
    </div>
</section>
