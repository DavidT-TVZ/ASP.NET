@model IEnumerable<DnD_Character_Sheet_Creator.Models.Player>

@{
    ViewData["Title"] = "Players";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Players</h1>
        <p class="text-muted mb-0">Mock player data from the repository.</p>
    </div>
</div>

<div class="row g-4">
    @foreach (var player in Model)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5 card-title">@player.Name @player.Surname</h2>
                    <p class="card-text mb-1"><strong>Username:</strong> @player.Username</p>
                    <p class="card-text mb-1"><strong>Email:</strong> @player.Email</p>
                    <p class="card-text mb-1"><strong>Last Login:</strong> @player.LastLogin.ToString("u")</p>
                    <p class="card-text mb-0"><strong>Characters:</strong> @player.CharacterList.Count</p>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@player.PlayerId">View details</a>
                </div>
            </div>
        </div>
    }
</div>
