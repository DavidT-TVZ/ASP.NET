@model IEnumerable<DnD_Character_Sheet_Creator.Models.Player>

@{
    ViewData["Title"] = "Players";
}

<div class="sheet-card mb-4 reveal d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div>
        <p class="sheet-kicker mb-1">Guild Register</p>
        <h1 class="h3 mb-1">Players</h1>
        <p class="text-muted mb-0">Explore all registered players and their linked heroes.</p>
    </div>
    <span class="badge chronicle-badge rounded-pill px-3 py-2">@Model.Count() total</span>
</div>

<div class="row g-4">
    @foreach (var player in Model)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card sheet-card card-hover h-100 reveal">
                <div class="card-body">
                    <h2 class="h5 card-title mb-3">@player.Name @player.Surname</h2>
                    <p class="card-text mb-1"><strong>Username:</strong> @player.Username</p>
                    <p class="card-text mb-1"><strong>Email:</strong> @player.Email</p>
                    <p class="card-text mb-1"><strong>Last Login:</strong> <time datetime="@player.LastLogin.ToString("o")">@player.LastLogin.ToString("u")</time></p>
                    <p class="card-text mb-0"><strong>Characters:</strong> @player.CharacterList.Count</p>
                </div>
                <div class="card-footer bg-transparent border-top-0">
                    <a class="btn btn-outline-ink btn-sm" asp-action="Details" asp-route-id="@player.PlayerId">View details</a>
                </div>
            </div>
        </div>
    }
</div>
